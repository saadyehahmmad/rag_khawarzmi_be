# Anthropic API key — https://console.anthropic.com/ (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI API key — https://platform.openai.com/ (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Google AI (Gemini / Gemma) — https://aistudio.google.com/apikey (when LLM_PROVIDER=gemma)
# GOOGLE_API_KEY=...

# Chat vendor: anthropic | openai | gemma (Google AI) | ollama (local; alias: local)
# LLM_PROVIDER=anthropic

# Ollama OpenAI-compatible base URL (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Catalog vector DB: chroma (on-disk under VECTOR_STORE_PATH) or qdrant (typo qudrant accepted).
# Survey session indexes remain Chroma regardless of this setting.
# VECTOR_BACKEND=chroma

# Qdrant HTTP API (when VECTOR_BACKEND=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_PREFER_GRPC=false

# Local multilingual embeddings (no API key)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# LLM model id (meaning depends on LLM_PROVIDER — e.g. claude-*, gpt-*, gemma-*)
LLM_MODEL=claude-sonnet-4-20250514

VECTOR_STORE_PATH=./vector_stores
LOG_PATH=./logs

# --- Observability (core/observability.py) ---
# LOG_LEVEL=INFO
# JSON logs to stderr for log stacks (otherwise text format adds [rid=… tid=…]).
# OBSERVABILITY_JSON_STDOUT=false
# Append-only JSONL for RAG completion metrics (same events as logger rag.rag).
# OBSERVABILITY_METRICS_LOG=./logs/rag_metrics.jsonl
# Optional build / release label on GET /health.
# APP_VERSION=1.0.0

# Comma-separated Latin tokens to skip English spell-fix (names, brands).
# QUERY_TYPO_BLOCKLIST=abdullah,customco

# Thread memory: JSON files under MEMORY_PATH/threads/ when REDIS_URL is unset.
MEMORY_PATH=./memory
MEMORY_MAX_TURNS=10

# Optional Redis for shared, durable thread history (multi-instance API, restarts).
# Example: redis://localhost:6379/0
# REDIS_URL=
# Key prefix for lists rag:thread:<id>:turns
# REDIS_KEY_PREFIX=rag:thread:
# Seconds until thread key expires (0 = no TTL)
# REDIS_MEMORY_TTL=0

# Optional: if set, /chat and /chat/sync require Bearer, X-API-Key, or ?api_key=
# RAG_API_KEY=your-long-random-secret

# Optional: if set, /health/ready requires Bearer or X-API-Key matching this value.
# Leave unset for load-balancer probes (no auth).
# RAG_HEALTH_READY_KEY=

# --- Governance & guardrails (core/governance.py) ---
# GOVERNANCE_ENABLED=true
# Max characters for the user question (DoS / cost control)
# GOVERNANCE_MAX_QUESTION_CHARS=12000
# Comma-separated substrings; if any match (case-insensitive), request is rejected (403)
# GOVERNANCE_BLOCK_SUBSTRINGS=
# Optional path to newline-separated block phrases (# comments allowed)
# GOVERNANCE_BLOCKLIST_FILE=
# Append-only JSONL of blocked attempts (prefix + hash only; set path to enable)
# GOVERNANCE_AUDIT_LOG=./logs/governance_audit.jsonl
# Per-client requests per minute (429). Use Redis in production for multi-worker accuracy.
# Default 60 protects the API out of the box; set 0 to disable for local dev.
# GOVERNANCE_RATE_LIMIT_PER_MINUTE=60

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins for CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4202,http://192.168.2.132:4200

# Optional: one large .md ingested into all four system collections (same chunks, 4 stores)
# KNOWLEDGE_MONOLITH=./al-khwarizmi-systems-rag.md

# Comma-separated system names — must match docs/ subdirectories and vector_stores/.
# Add new systems here without any code changes.
# RAG_SYSTEMS=designer,runtime,callcenter,admin

# --- Retrieval (framework/nodes, core/retrieval.py) ---
# RETRIEVAL_TOP_K=8
# RETRIEVAL_FETCH_K=24
# RETRIEVAL_MMR_LAMBDA=0.5
# RETRIEVAL_USE_MMR=true
# RETRIEVAL_NORMALIZE_AR=true
# Hybrid: dense vector-store pool + BM25 + RRF (disable for legacy dense-only).
# RETRIEVAL_HYBRID=true
# HYBRID_DENSE_POOL=32
# RRF_K=60
# Optional cross-encoder rerank (sentence-transformers); empty = off (saves load/latency).
# Enabling this significantly improves retrieval precision at the cost of ~100-200 ms.
# Recommended multilingual model for Arabic + English:
# RERANK_CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_POOL=24
# RERANK_MAX_CHARS=1024
# Minimum non-empty chunks to auto-mark retrieval as relevant (skips the L2 gate).
# Set to 0 to always apply the L2 gate; raise if BM25 alone surfaces enough signal.
# RETRIEVAL_MIN_RELEVANT_CHUNKS=3
# Hard L2 fallback gate — only applied when fewer than MIN_RELEVANT_CHUNKS chunks were returned.
# Normalized e5-large: 0=identical, 1.6=far off, 2=completely unrelated.
# Omit or leave empty to rely on chunk count alone.
# RETRIEVAL_RELEVANCE_MAX_L2=1.6

# --- LLM output length (answer completeness) ---
# Max tokens for the final answer. Raise if long step-by-step answers are cut off.
# LLM_MAX_TOKENS=4096

# --- LLM transient error retries ---
# LLM_MAX_RETRIES=3
# LLM_RETRY_BASE_SEC=0.6

# --- API startup: fail if catalog vector stores are missing (operator guard) ---
# RAG_REQUIRE_VECTOR_STORES=false

# --- Output safety (core/output_safety.py) ---
# When true, answer_node substitutes the fallback message if any safety flag is raised.
# Leave unset for monitoring-only mode (flags are logged but answers are still returned).
# SAFETY_STRICT=false


# --- Ingestion (ingestion/config.py, chroma_ingest.py) ---
# Catalog backend must match VECTOR_BACKEND (chroma on-disk vs qdrant).
# Remove vector_stores/<system>/ before each folder re-ingest (idempotent; default true).
# INGEST_CLEAN_STORE=true
# INGEST_CHUNK_SIZE=1100
# INGEST_CHUNK_OVERLAP=150
